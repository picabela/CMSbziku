{
    "name": "Gazette",
    "slug": "gazette",
    "version": "1.0.0",
    "author": "bziku CMS",
    "description": "Międzynarodowa gazeta dzienna w stylu Le Monde / Guardian. Wyraziste czerwone akcenty, klasyczna Playfair, jasne tło. Dobre dla wiadomości politycznych i biznesowych.",
    "tags": ["newspaper", "international", "red-accent", "elegant"],
    "supports": ["dark-mode", "responsive", "hamburger-menu", "tag-cloud"],
    "preview_color": "#c8102e",
    "screenshot": "screenshot.svg",
    "fonts": ["Playfair Display", "Source Serif 4", "Inter"],
    "customizable_colors": [
        {"var": "--ink", "label": "Tekst główny", "default": "#1a1a1a"},
        {"var": "--paper", "label": "Tło", "default": "#ffffff"},
        {"var": "--paper-bright", "label": "Tło treści", "default": "#fafafa"},
        {"var": "--accent", "label": "Akcent (czerwony)", "default": "#c8102e"},
        {"var": "--muted", "label": "Tekst poboczny", "default": "#666666"}
    ]
}
