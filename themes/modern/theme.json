{
    "name": "Modern Tech Magazine",
    "slug": "modern",
    "version": "1.0.0",
    "author": "bziku CMS",
    "description": "Nowoczesny tech-magazine: Inter sans-serif, czerwony akcent, miękkie cienie, zaokrąglone karty, generous whitespace. Bez drop cap, bez justify. Optymalizacja pod tablety i czytelność na ekranach LCD.",
    "tags": ["modern", "magazine", "sans-serif", "accent", "rounded", "tech"],
    "supports": ["dark-mode", "responsive", "hamburger-menu", "tag-cloud"],
    "preview_color": "#e63946",
    "screenshot": "screenshot.svg",
    "fonts": ["Inter"],
    "customizable_colors": [
        {"var": "--ink", "label": "Tekst główny", "default": "#1a1a2e"},
        {"var": "--paper", "label": "Tło strony", "default": "#fafbfc"},
        {"var": "--paper-bright", "label": "Tło kart", "default": "#ffffff"},
        {"var": "--muted", "label": "Tekst poboczny", "default": "#6b6f7d"},
        {"var": "--accent", "label": "Akcent (przyciski, linki)", "default": "#e63946"},
        {"var": "--accent-soft", "label": "Akcent miękki (tła)", "default": "#fde8ea"},
        {"var": "--accent-dark", "label": "Akcent ciemny (hover)", "default": "#c41e2e"}
    ],
    "requires_php": "8.0",
    "tested_with": "1.0"
}
