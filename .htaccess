# bziku CMS — friendly URLs and security
Options -Indexes
DirectoryIndex index.php index.html

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Force trailing slash off (canonical URLs)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.+)/$ /$1 [R=301,L]

    # Block direct access to includes, data and CLI bin
    RewriteRule ^includes/ - [F,L]
    RewriteRule ^data/ - [F,L]
    RewriteRule ^bin/ - [F,L]

    # sitemap.xml -> sitemap.php
    RewriteRule ^sitemap\.xml$ sitemap.php [L]

    # /kontakt -> kontakt.php
    RewriteRule ^kontakt/?$ kontakt.php [L]

    # Category pages: /kategoria/seo  -> index.php?kategoria=seo
    RewriteRule ^kategoria/([a-z0-9-]+)/?$ index.php?kategoria=$1 [QSA,L]

    # Tag pages: /tag/google -> tag.php?tag=google
    RewriteRule ^tag/([a-z0-9-]+)/?$ tag.php?tag=$1 [QSA,L]

    # Static pages: /strona/o-nas -> strona.php?slug=o-nas
    RewriteRule ^strona/([a-z0-9-]+)/?$ strona.php?slug=$1 [QSA,L]

    # Skip real files & directories
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Single article: /my-article-slug -> article.php?slug=my-article-slug
    RewriteRule ^([a-z0-9-]+)/?$ article.php?slug=$1 [QSA,L]
</IfModule>

# Compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml text/xml application/xml
</IfModule>

# Browser caching
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "interest-cohort=()"
</IfModule>

# Protect sensitive files
<FilesMatch "\.(sqlite|sqlite3|db|env|ini|log|md)$">
    Require all denied
</FilesMatch>
